# DenialNet™ — Environment Variables
# Copy to .env and fill in values

# ── Database ─────────────────────────────────────────────────────────────────
# Local SQLite for dev
DATABASE_URL=sqlite:///./denialnet.db

# Render PostgreSQL (production)
# DATABASE_URL=postgresql://user:pass@host:5432/denialnet

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get from dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# ── App Settings ───────────────────────────────────────────────────────────────
DENIALNET_QUERY_COST_CENTS=75
DENIALNET_MIN_CREDITS_CENTS=500
DENIALNET_CONTRIBUTOR_SPLIT=0.70
DENIALNET_NETWORK_SPLIT=0.30
DENIALNET_MIN_SAMPLE_SIZE=3
# API Authentication (generate with: python3 -c "import uuid; print(uuid.uuid4().hex + uuid.uuid4().hex)")
DENIALNET_ADMIN_API_KEY=

# Redis URL (optional — enables Redis-backed rate limiting; in-memory fallback if unset)
DENIALNET_REDIS_URL=

# Stripe (required for live payments)
DENIALNET_STRIPE_SECRET_KEY=
DENIALNET_STRIPE_WEBHOOK_SECRET=
